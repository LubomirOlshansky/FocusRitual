    <string name="settings_legal_terms_subtitle">Uso de FocusRitual</string>
    <string name="settings_legal_privacy_storage_title">Qué guarda FocusRitual</string>
    <string name="settings_legal_privacy_storage_body">FocusRitual guarda en este dispositivo tus elecciones de temporizador, mezclas ambientales, preferencias de audio y ajustes de la app para restaurar tu espacio entre sesiones.</string>
    <string name="settings_legal_privacy_activity_title">Audio y actividad de enfoque</string>
    <string name="settings_legal_privacy_activity_body">La app reproduce sonidos ambientales incluidos y registra el estado necesario para temporizadores, actividades en vivo y controles de reproducción. FocusRitual no requiere una cuenta para usar el mezclador principal.</string>
    <string name="settings_legal_privacy_platform_title">Servicios de plataforma</string>
    <string name="settings_legal_privacy_platform_body">Algunas acciones usan funciones del sistema, como correo, ajustes de idioma, compartir, sesiones de audio, notificaciones y protecciones de enfoque opcionales. El sistema operativo las gestiona y pueden estar sujetas a los términos de privacidad de Apple o Google.</string>
    <string name="settings_legal_privacy_support_title">Contacto de soporte</string>
    <string name="settings_legal_privacy_support_body">Cuando contactas con FocusRitual, tu app de correo crea el mensaje. Incluye solo los detalles que quieras compartir. La app puede rellenar la versión instalada para ayudar a resolver problemas.</string>
    <string name="settings_legal_privacy_production_title">Nota de producción</string>
    <string name="settings_legal_privacy_production_body">Este texto interno se generó para la experiencia de FocusRitual y debe revisarse antes del lanzamiento donde se requiera una política formal.</string>
    <string name="settings_legal_terms_personal_title">Herramienta personal de enfoque</string>
    <string name="settings_legal_terms_personal_body">FocusRitual se ofrece como compañero de sonidos ambientales y temporizador. Úsalo para enfoque, descanso y planificación, y elige volúmenes seguros para tu entorno.</string>
    <string name="settings_legal_terms_advice_title">Sin asesoramiento profesional</string>
    <string name="settings_legal_terms_advice_body">La app puede apoyar rutinas y concentración, pero no es asesoramiento médico, terapéutico, legal ni de productividad. Detén la sesión si se siente incómoda o insegura.</string>
    <string name="settings_legal_terms_audio_title">Contenido de audio</string>
    <string name="settings_legal_terms_audio_body">Los sonidos incluidos pueden contener material original de FocusRitual y audio de terceros acreditado en Créditos de sonido. No extraigas, redistribuyas ni reutilices el audio fuera de la app salvo que la licencia lo permita.</string>
    <string name="settings_legal_terms_platform_title">Limitaciones de plataforma</string>
    <string name="settings_legal_terms_platform_body">La mezcla, atenuación, idioma, protecciones de enfoque, actividades en vivo y notificaciones dependen del sistema y permisos. La disponibilidad puede variar por dispositivo, versión y ajustes.</string>
    <string name="settings_legal_terms_production_title">Nota de producción</string>
    <string name="settings_legal_terms_production_body">Este texto interno se generó para FocusRitual y debe revisarse antes del lanzamiento donde se requieran términos formales.</string>
