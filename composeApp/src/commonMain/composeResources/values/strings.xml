    <string name="settings_legal_terms_subtitle">Using FocusRitual</string>
    <string name="settings_legal_privacy_storage_title">What FocusRitual stores</string>
    <string name="settings_legal_privacy_storage_body">FocusRitual stores your focus timer choices, ambient mix settings, audio preferences, and app settings on this device so the app can restore your workspace between sessions.</string>
    <string name="settings_legal_privacy_activity_title">Audio and focus activity</string>
    <string name="settings_legal_privacy_activity_body">The app plays bundled ambient sounds and tracks session state needed for timers, live activities, and playback controls. FocusRitual does not require an account to use the core ambient mixer.</string>
    <string name="settings_legal_privacy_platform_title">Platform services</string>
    <string name="settings_legal_privacy_platform_body">Some actions use platform features such as email composition, app language settings, sharing, audio sessions, notifications, and optional focus protections. Those actions are handled by the operating system and may be subject to Apple or Google privacy terms.</string>
    <string name="settings_legal_privacy_support_title">Support contact</string>
    <string name="settings_legal_privacy_support_body">When you contact FocusRitual, your email app creates the message. Include only the details you want to share. The app may prefill the installed version to help troubleshoot issues.</string>
    <string name="settings_legal_privacy_production_title">Production note</string>
    <string name="settings_legal_privacy_production_body">This in-app text is generated for the FocusRitual experience and should be reviewed before release anywhere a formal privacy policy is required.</string>
    <string name="settings_legal_terms_personal_title">Personal focus tool</string>
    <string name="settings_legal_terms_personal_body">FocusRitual is provided as an ambient sound and focus timer companion. Use it for personal focus, rest, and planning, and choose volume levels that are safe for your environment.</string>
    <string name="settings_legal_terms_advice_title">No professional advice</string>
    <string name="settings_legal_terms_advice_body">The app can support routines and concentration, but it is not medical, therapeutic, legal, or productivity advice. Stop using a session if it feels uncomfortable or unsafe.</string>
    <string name="settings_legal_terms_audio_title">Audio content</string>
    <string name="settings_legal_terms_audio_body">Bundled sounds may include original FocusRitual material and third-party audio credited in the Sound Credits screen. Do not extract, redistribute, or reuse the bundled audio outside the app unless the listed license allows it.</string>
    <string name="settings_legal_terms_platform_title">Platform limitations</string>
    <string name="settings_legal_terms_platform_body">Audio mixing, ducking, language settings, focus protections, live activities, and notifications depend on platform behavior and permissions. Availability may vary by device, operating system version, and user settings.</string>
    <string name="settings_legal_terms_production_title">Production note</string>
    <string name="settings_legal_terms_production_body">This in-app text is generated for the FocusRitual experience and should be reviewed before release anywhere formal terms are required.</string>

